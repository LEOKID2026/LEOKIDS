{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/hebrew-official-provenance.schema.json",
  "title": "Hebrew alignment official_provenance",
  "type": "object",
  "required": [
    "schema_version",
    "mapping_status",
    "official_objective_source",
    "mapped_at",
    "confidence"
  ],
  "allOf": [
    {
      "if": {
        "properties": { "mapping_status": { "const": "file_bound_excerpt_linked" } },
        "required": ["mapping_status"]
      },
      "then": {
        "required": [
          "official_section_anchor",
          "official_doc_excerpt_ref",
          "official_doc_id",
          "source_files_in_repo",
          "source_language_expected",
          "source_subject_expected"
        ],
        "properties": {
          "official_section_anchor": { "type": "string", "minLength": 4 },
          "official_doc_excerpt_ref": { "type": "string", "minLength": 3 },
          "official_doc_id": { "type": "string", "minLength": 8 },
          "source_files_in_repo": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "official_objective_source": { "const": "ministry_summary_verified" } },
        "required": ["official_objective_source"]
      },
      "then": {
        "required": ["summary_alignment_justification"],
        "properties": {
          "summary_alignment_justification": { "type": "string", "minLength": 16 }
        }
      }
    },
    {
      "if": {
        "properties": { "mapping_status": { "const": "file_bound_excerpt_pending" } },
        "required": ["mapping_status"]
      },
      "then": {
        "required": [
          "official_doc_id",
          "source_files_in_repo",
          "source_language_expected",
          "source_subject_expected"
        ],
        "properties": {
          "official_objective_source": { "const": "internal_working_statement" },
          "official_section_anchor": { "type": "null" },
          "official_doc_excerpt_ref": { "type": "null" },
          "summary_alignment_justification": { "type": "null" }
        }
      }
    }
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "mapping_status": {
      "type": "string",
      "enum": [
        "pending_hebrew_ministry_primary",
        "file_bound_excerpt_pending",
        "file_bound_excerpt_linked",
        "superseded_internal_only"
      ]
    },
    "source_language_expected": { "type": "string", "enum": ["he", "mixed", "unknown"] },
    "source_subject_expected": {
      "type": "string",
      "enum": ["lashon_hebrew", "english", "mathematics", "other", "unknown"]
    },
    "source_files_in_repo": {
      "type": "array",
      "items": { "type": "string" },
      "description": "נתיבים יחסיים לשורש הריפו"
    },
    "repo_txt_catalog_ref": {
      "type": "string",
      "const": "data/hebrew-ministry-source-catalog.json"
    },
    "official_doc_id": { "type": ["string", "null"] },
    "official_section_anchor": { "type": ["string", "null"] },
    "official_objective_source": {
      "type": "string",
      "enum": ["internal_working_statement", "ministry_excerpt_verbatim", "ministry_summary_verified"]
    },
    "official_doc_excerpt_ref": { "type": ["string", "null"] },
    "summary_alignment_justification": {
      "type": ["string", "null"],
      "description": "חובה כאשר official_objective_source הוא ministry_summary_verified — מדוע הסיכום נשען על הקטע המצוטט"
    },
    "mapped_at": { "type": "string", "minLength": 8 },
    "confidence": {
      "type": "string",
      "enum": ["none_until_hebrew_primary_linked", "low", "medium", "high"]
    },
    "reviewer_notes": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}

# Classroom Activities (teacher portal): required for student home "פעילויות כיתה" in dev/production.
NEXT_PUBLIC_ACTIVITIES_ENABLED=true

NEXT_PUBLIC_PARENT_COPILOT_V1=1

# Short-report Parent Copilot (Phase D): safe production default is OFF — do not enable for public launch until
# server-side report snapshot exists for /api/parent/copilot-turn (see docs/parent-ai/final-status.md).
NEXT_PUBLIC_ENABLE_PARENT_COPILOT_ON_SHORT=false

# Phase D (optional dev): turn short-report Copilot on locally only after rebuild when testing.
# NEXT_PUBLIC_ENABLE_PARENT_COPILOT_ON_SHORT=true

# Phase D.1: allow unauthenticated client payload for /api/parent/copilot-turn in development only (default on in dev).
# Set to "false" to require student cookie or parent Bearer + studentId (production never allows unauth).
# PARENT_COPILOT_ALLOW_UNAUTH_LOCAL_PAYLOAD=false

# Emergency / controlled environments ONLY — NOT for public production launch.
# When "true", production may execute Copilot against a client-supplied report snapshot (trusts the browser).
# Leave unset or "false" for launch; see docs/parent-ai/copilot-turn-production.md.
# PARENT_COPILOT_ALLOW_CLIENT_PAYLOAD_IN_PRODUCTION=true

# Parent Copilot rollout / quality gates
PARENT_COPILOT_ROLLOUT_STAGE=full
PARENT_COPILOT_LLM_ENABLED=true
PARENT_COPILOT_FORCE_DETERMINISTIC=false
PARENT_COPILOT_KPI_MIN_FLUENCY=75
PARENT_COPILOT_KPI_MIN_GROUNDEDNESS=85
PARENT_COPILOT_KPI_MAX_GENERICNESS=42
PARENT_COPILOT_KPI_MAX_FALLBACK_RATE=0.2
PARENT_COPILOT_KPI_MIN_CLARIFICATION_SUCCESS=0.6

# Optional grounded LLM settings (שאלו על הדוח / Parent Copilot Q&A). Provider defaults to OpenAI-compatible.
# For Gemini: PARENT_COPILOT_LLM_PROVIDER=gemini + GEMINI_API_KEY (server-only; never NEXT_PUBLIC_*).
PARENT_COPILOT_LLM_PROVIDER=openai
PARENT_COPILOT_LLM_BASE_URL=https://api.openai.com/v1/responses
PARENT_COPILOT_LLM_MODEL=gpt-4.1-mini
PARENT_COPILOT_LLM_TIMEOUT_MS=9000
PARENT_COPILOT_LLM_API_KEY=
# Gemini (when PARENT_COPILOT_LLM_PROVIDER=gemini); optional BASE_URL override:
# PARENT_COPILOT_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_API_KEY=
# If gemini-2.5-flash returns HTTP 429 often (free tier / overload), try a lighter model:
# PARENT_COPILOT_LLM_MODEL=gemini-2.5-flash-lite
# Async live smoke: pause between report-related questions (ms; default 2500 in script)
# PARENT_COPILOT_ASYNC_SMOKE_DELAY_MS=2500

# Parent Report — AI narrative ("סיכום חכם להורה"), server-side only.
# Never use NEXT_PUBLIC_* for API keys; never commit real secrets.
# Vercel: Project Settings → Environment Variables → add for Preview and/or Production, then redeploy.
PARENT_REPORT_NARRATIVE_LLM_PROVIDER=gemini
PARENT_REPORT_NARRATIVE_LLM_MODEL=gemini-2.5-flash
PARENT_REPORT_NARRATIVE_LLM_ENABLED=true
GEMINI_API_KEY=
# Optional overrides (defaults match googleapis Generative Language API):
# PARENT_REPORT_NARRATIVE_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# PARENT_REPORT_NARRATIVE_LLM_TIMEOUT_MS=25000
# PARENT_REPORT_NARRATIVE_FORCE_DETERMINISTIC=true

# Learning book page audio (pre-generated MP3 playback). Default OFF — fail closed in production.
# Client: show audio player on learning book pages when manifest entry exists.
# NEXT_PUBLIC_LEARNING_BOOK_AUDIO_ENABLED=true
# Server/scripts: allow offline audio generation script (not required for build).
# LEARNING_BOOK_AUDIO_ENABLED=true

# Math scratchpad workspace ("דף טיוטה") — Phase 2 MVP. Default OFF until owner QA approval.
# NEXT_PUBLIC_MATH_SCRATCHPAD_V1=true

# Student identity tracing (dev only): `console` + `debugStudentIdentity` on login/me when true.
# Restart `next dev` after changing. Never enable in public production for noisy logs.
# NEXT_PUBLIC_DEBUG_STUDENT_IDENTITY=true

# Learning-site Supabase (Phase 1 foundation)
NEXT_PUBLIC_LEARNING_SUPABASE_URL=https://ajxwmlwbzxwffrtlfuoe.supabase.co
NEXT_PUBLIC_LEARNING_SUPABASE_ANON_KEY=
LEARNING_SUPABASE_SERVICE_ROLE_KEY=
LEARNING_STUDENT_ACCESS_SECRET=

# Parent Google sign-in (Google Identity Services on /parent/login)
# Use the SAME Web Client ID already configured in Supabase → Auth → Providers → Google.
# This value is public by design (OAuth Web client ID). Do not put the client secret here.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Legacy OAuth callback path kept for compatibility (/parent/auth/google-callback).
# Public app origin today: https://liosh-website.vercel.app
# Supabase → Authentication → URL Configuration → Redirect URLs (legacy callback, keep):
#   https://liosh-website.vercel.app/parent/auth/google-callback
# When a final domain exists, add a second Redirect URL (keep the Vercel one until cutover):
#   https://YOUR-FINAL-DOMAIN/parent/auth/google-callback
# Google Cloud Console → OAuth client → Authorized redirect URIs (Supabase callback, not the app):
#   https://ajxwmlwbzxwffrtlfuoe.supabase.co/auth/v1/callback
# Localhost redirect URLs are optional and not required for external QA on Vercel.

# Arcade (server): allow spends on disabled/foundation games — ONLY for controlled testing (default off)
# ARCADE_ALLOW_FOUNDATION_ACTIONS=true

# Arcade (client): show raw API JSON on /student/arcade when NODE_ENV=production
# NEXT_PUBLIC_ARCADE_DEBUG=true


# Internal Engine Expert Review Pack admin (`/learning/dev/engine-review`, internal API)
# Vercel: Project Settings → Environment Variables — set for Production (and Preview if needed).
# NEXT_PUBLIC_* must be present at build time. ENGINE_REVIEW_ADMIN_TOKEN is server-only.
# Use a long random secret — never commit a real token. Required for engine-review APIs in all environments.
NEXT_PUBLIC_ENABLE_ENGINE_REVIEW_ADMIN=false
ENGINE_REVIEW_ADMIN_TOKEN=replace-with-long-random-secret

# Card rewards system (cards, shop, surprise box, duplicates) — default OFF, no child-visible change until true.
CARD_REWARDS_ENABLED=false
NEXT_PUBLIC_CARD_REWARDS_ENABLED=false

# Coin economy — Admin/DB single source of truth. MUST be true in production.
# When false or DB incomplete: economy unavailable (fail-closed). No legacy hardcoded fallback.
REWARD_ECONOMY_SETTINGS_ENABLED=true
NEXT_PUBLIC_REWARD_ECONOMY_SETTINGS_ENABLED=true

# ── Student external ads (Google AdSense) + cookie consent ─────────────────────
# Default OFF. Do NOT enable until ALL of the following are true:
#   1. Google AdSense / ads account approved by Google
#   2. CMP (cookie/ads consent banner) deployed and tested
#   3. CSP updated in next.config.js (Google domains allowed)
#   4. Explicit owner sign-off for production launch
#
# NEXT_PUBLIC_STUDENT_AD_EXTERNAL_ENABLED=true
#
# Publisher / tag IDs — leave empty until Google provides real values (never hardcode fake IDs):
# NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_GOOGLE_TAG_ID=G-XXXXXXXXXX
#
# Without consent + these env vars, the site keeps the existing ad placeholder only.

# Admin manual coin credit to a specific child (compensation / bonus / bugfix) — default OFF.
ENABLE_ADMIN_MANUAL_COIN_CREDIT=false
NEXT_PUBLIC_ENABLE_ADMIN_MANUAL_COIN_CREDIT=false

# Monthly persistence coin awards — admin trigger + Vercel cron (previous Israel month).
ENABLE_MONTHLY_PERSISTENCE_REWARD_ADMIN=false
ENABLE_MONTHLY_PERSISTENCE_CRON=false
# Vercel Cron: set CRON_SECRET in project env; Vercel sends Authorization: Bearer automatically.
CRON_SECRET=replace-with-long-random-secret

# Contact form (/contact) delivery webhook — REQUIRED in production so real inquiries are not lost.
# Without it, submitContactForm() only logs (safeApiLog) and returns { ok:false, code:"delivery_not_configured" }.
CONTACT_FORM_WEBHOOK_URL=

# Public site origin overrides (optional). Safe fallback already resolves to the canonical domain
# (https://www.leokids.co.il) even when unset — documented here for completeness only.
# NEXT_PUBLIC_SITE_URL=
# NEXT_PUBLIC_APP_URL=

# Admin email override(s) (optional). Safe fallback: leokid2026@gmail.com.
# MAIN_ADMIN_EMAIL=
# MAIN_ADMIN_EMAILS=

# Vercel Web Analytics — server-only (Admin dashboard «תנועה באתר»). Never expose as NEXT_PUBLIC_*.
# VERCEL_ANALYTICS_ACCESS_TOKEN=
# VERCEL_ANALYTICS_PROJECT_ID=
# VERCEL_ANALYTICS_TEAM_ID=
